{
  "name": "auto-transcribed-screen-capture",
  "version": "0.1.1",
  "description": "A local CLI for narrated macOS screen demonstrations that coding agents can consume.",
  "license": "MIT",
  "homepage": "https://github.com/bnc4vk/auto-transcribed-screen-capture#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bnc4vk/auto-transcribed-screen-capture.git"
  },
  "bugs": {
    "url": "https://github.com/bnc4vk/auto-transcribed-screen-capture/issues"
  },
  "keywords": [
    "macos",
    "screen-capture",
    "coding-agents",
    "codex",
    "claude-code",
    "transcription",
    "faster-whisper"
  ],
  "type": "module",
  "files": [
    "dist/",
    "scripts/",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "bin": {
    "atsc": "dist/cli.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "test": "npm run build && node --test tests/*.test.mjs",
    "start": "node dist/cli.js",
    "setup-transcriber": "node dist/cli.js setup-transcriber"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
